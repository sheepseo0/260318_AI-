   "source": [
    "n = int(input('합계를 구할 수를 입력하세요 : '))\n",
    "s = 0\n",
    "for i in range(0, n) :\n",
    "    s = s + (i+1)\n",
    "print('1부터 {}까지의 합은 {}'.format(n, s))"
